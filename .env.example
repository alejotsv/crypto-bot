ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Auto-entry (feature 9) -- off by default. Set to true to let the cron
# cycle place automatic trades on the 6 tracked symbols (see
# crypto_bot/strategy.py's AUTO_ENTRY_SYMBOLS).
AUTO_ENTRY_ENABLED=false
# Per-symbol notional per triggered entry. 10 is Alpaca's crypto
# minimum and is only a fallback -- set this to your own intended
# per-trade amount.
AUTO_ENTRY_NOTIONAL=10

# Optional spending caps on top of the live buying-power check (ADR
# 0006), auto-entry only -- 0 disables a cap, any value >0 enables it
# at that dollar amount. TOTAL never resets automatically; DAILY resets
# each UTC calendar day.
AUTO_ENTRY_TOTAL_CAP=1000
AUTO_ENTRY_DAILY_CAP=200

# Telegram bot (feature 10) -- required. Get TELEGRAM_BOT_TOKEN from
# @BotFather, TELEGRAM_CHAT_ID from @userinfobot (or similar) once
# you've messaged your bot at least once.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Dollar amount used by /buy SYMBOL when AMOUNT is omitted, and by the
# "Buy" button. Always overridable inline (/buy SYMBOL 25).
DEFAULT_ORDER_NOTIONAL=
# Symbol used by the "Buy" button. Optional, defaults to BTC/USD.
DEFAULT_ORDER_SYMBOL=BTC/USD
